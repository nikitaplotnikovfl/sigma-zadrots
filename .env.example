# --- Секреты/конфиг (скопируй в .env и заполни) ---

# FACEIT server-side API key (developers.faceit.com -> My Apps)
FACEIT_API_KEY=

# Postgres (прод — Neon). Пример Neon:
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Реальная hub-очередь клуба SIGMA ZADROTS (не id из /club/ в URL!)
HUB_ID=d0701937-8eba-4df9-8830-22137001c0bd

# Токен для админ-ручек (POST /api/sync). Поменяй на свой.
ADMIN_TOKEN=change-me

# Сборщик
SYNC_INTERVAL_CRON=*/10 * * * *
SYNC_PAGE_LIMIT=100
SYNC_MIN_INTERVAL_MS=600

# Порт API (Railway подставит свой PORT автоматически)
PORT=3000

# Логирование: trace|debug|info|warn|error (default info). В проде вывод — JSON.
LOG_LEVEL=info
