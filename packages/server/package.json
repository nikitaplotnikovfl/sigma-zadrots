{
  "name": "@sigma/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:prod": "prisma migrate deploy && tsx src/server.ts",
    "sync": "tsx src/syncCli.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
