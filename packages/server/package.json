    "studio": "prisma studio",
    "test": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.20.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.20.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
