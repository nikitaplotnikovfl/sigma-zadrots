// SIGMA ZADROTS — схема БД (SQLite локально; провайдер меняется на postgresql в проде)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Отслеживаемый турнир (FACEIT hub или championship)
model Source {
  id      String   @id // faceit hub/championship id
  type    String // "hub" | "championship"
  name    String
  game    String
  addedAt DateTime @default(now())
  matches Match[]
}

model Player {
  id        String             @id // faceit player_id
  nickname  String
  avatar    String?
  country   String?
  faceitUrl String?
  updatedAt DateTime           @updatedAt
  stats     PlayerMatchStats[]
  aggregate PlayerAggregate?
}

model Match {
  id           String             @id // faceit match_id
  sourceId     String
  competition  String?
  region       String?
  status       String?
  bestOf       Int                @default(1)
  startedAt    DateTime?
  finishedAt   DateTime?
  winnerTeamId String?
  teamsJson    String? // [{teamId,name,score,isWinner}] — серия (карт выиграно)
  mapsJson     String? // [{mapNum,mapName,teams:[{teamId,name,score,isWinner}]}]
  createdAt    DateTime           @default(now())
  source       Source             @relation(fields: [sourceId], references: [id])
  stats        PlayerMatchStats[]

  @@index([sourceId, finishedAt])
}

// Строка статистики игрока за карту матча
model PlayerMatchStats {
  id           String   @id // `${matchId}:${mapNum}:${playerId}`
  matchId      String
  playerId     String
  mapNum       Int      @default(1)
  mapName      String?
  teamId       String?
  teamName     String?
  won          Boolean  @default(false)
  kills        Int      @default(0)
  deaths       Int      @default(0)
  assists      Int      @default(0)
  kd           Float    @default(0)
  kr           Float    @default(0)
  adr          Float    @default(0)
  headshots    Int      @default(0)
  hsPct        Float    @default(0)
  mvps         Int      @default(0)
  doubleKills  Int      @default(0)
  tripleKills  Int      @default(0)
  quadroKills  Int      @default(0)
  pentaKills   Int      @default(0)
  rounds       Int      @default(0) // раундов на этой карте (сумма Final Score обеих команд)
  entryCount     Int    @default(0)
  entryWins      Int    @default(0)
  firstKills     Int    @default(0)
  clutchKills    Int    @default(0)
  clutch1v1Count Int    @default(0)
  clutch1v1Wins  Int    @default(0)
  clutch1v2Count Int    @default(0)
  clutch1v2Wins  Int    @default(0)
  finishedAt   DateTime?
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([matchId])
}

// Предрасчитанные агрегаты игрока для лидерборда
model PlayerAggregate {
  playerId    String   @id
  matches     Int      @default(0)
  wins        Int      @default(0)
  winrate     Float    @default(0)
  kills       Int      @default(0)
  deaths      Int      @default(0)
  assists     Int      @default(0)
  kd          Float    @default(0)
  kr          Float    @default(0)
  adr         Float    @default(0)
  hsPct       Float    @default(0)
  mvps        Int      @default(0)
  doubleKills Int      @default(0)
  tripleKills Int      @default(0)
  quadroKills Int      @default(0)
  pentaKills  Int      @default(0)
  rounds      Int      @default(0)
  entryCount     Int    @default(0)
  entryWins      Int    @default(0)
  firstKills     Int    @default(0)
  clutchKills    Int    @default(0)
  clutch1v1Count Int    @default(0)
  clutch1v1Wins  Int    @default(0)
  clutch1v2Count Int    @default(0)
  clutch1v2Wins  Int    @default(0)
  rating      Float    @default(0)
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

// Снимок рангов лидерборда: пишется батчем на каждом синке для расчёта движения (rankDelta)
model RankSnapshot {
  id       Int      @id @default(autoincrement())
  playerId String
  rank     Int
  rating   Float
  takenAt  DateTime @default(now())

  @@index([takenAt])
  @@index([playerId])
}

model SyncRun {
  id          Int       @id @default(autoincrement())
  sourceId    String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  matchesSeen Int       @default(0)
  matchesNew  Int       @default(0)
  status      String    @default("running") // running | ok | error
  error       String?
}
